{
  "name": "@sweep/dashboard",
  "version": "0.0.1",
  "description": "Sweep dashboard — local Express + vanilla web UI for dispute-letter generation",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx --watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
